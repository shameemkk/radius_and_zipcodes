# Copy to .env and adjust as needed.

# Path to the SQLite/SpatiaLite database file.
DB_PATH=./data/zipcodes.db

# Port the API listens on.
PORT=3000

# Optional: full path to the mod_spatialite library. Only needed if the bare
# name can't be resolved by the OS loader (common on native Windows, where you
# point this at mod_spatialite.dll from the SpatiaLite Windows binaries).
# SPATIALITE_PATH=
