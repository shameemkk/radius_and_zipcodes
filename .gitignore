# ───────────────────────── Dependencies ─────────────────────────
node_modules/
.npm/
jspm_packages/

# ───────────────────── Environment / secrets ────────────────────
# Never commit real credentials/connection strings. The example is tracked.
.env
.env.*
!.env.example

# ───────────── SQLite / SpatiaLite database artifacts ────────────
# Built from GeoNames data; large and fully regenerable (see README →
# "Refreshing the data"). The deployable artifact is the Docker image, which
# bakes in seed/zipcodes.db — the DB does not belong in version control.
*.db
*.sqlite
*.sqlite3
*-wal
*-shm
*-journal

# ──────────── Source data & build seed ──────────────────────────
# The GeoNames source .txt ARE committed — the Docker build builds the database
# from them (see Dockerfile "seeder" stage). The generated *.db / *-wal / *-shm
# stay ignored by the database-artifacts rules above. The old build seed dir is
# no longer used.
seed/

# ──────────────────────────── Logs ──────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────── Test / build output ──────────────────────
coverage/
.nyc_output/
dist/
build/
*.tsbuildinfo

# ─────────────────────────── OS cruft ───────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ───────────────────────── Editors / IDEs ───────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────── Temp / scratch files ───────────────────
tmp/
*.tmp
_*.sh
